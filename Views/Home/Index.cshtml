@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<div class="jumbotron bg-light p-5 rounded-lg m-3">
    <h1 class="display-4">Welcome to FirstMvcApp</h1>
    <p class="lead">Building modern web applications with ASP.NET Core</p>
    <hr class="my-4">
    <p>This is a professional MVC application demonstrating best practices in ASP.NET Core development.</p>
    <a class="btn btn-primary btn-lg" href="@Url.Action("Index", "About")" role="button">Learn More</a>
</div>

<!-- Features Section -->
<div class="container my-5">
    <h2 class="mb-4 text-center">Our Features</h2>
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Modern Architecture</h5>
                    <p class="card-text">Built with the latest ASP.NET Core framework following MVC pattern for clean, maintainable code.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Responsive Design</h5>
                    <p class="card-text">Fully responsive Bootstrap templates that work seamlessly across all devices and screen sizes.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Easy to Extend</h5>
                    <p class="card-text">Simple structure makes it easy to add new controllers, views, and features to your application.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Call to Action Section -->
<div class="bg-light py-5">
    <div class="container text-center">
        <h3>Ready to Get Started?</h3>
        <p class="text-muted">Explore more about this application and how to use it.</p>
        <a href="@Url.Action("Index", "About")" class="btn btn-outline-primary me-2">About Us</a>
        <a href="@Url.Action("Privacy", "Home")" class="btn btn-outline-secondary">Privacy Policy</a>
    </div>
</div>
