@{
    ViewData["Title"] = "About Us";
}

<!-- Header Section -->
<div class="bg-primary text-white p-5 rounded mb-4">
    <h1 class="display-4">About Us</h1>
    <p class="lead">Learn more about FirstMvcApp and our mission</p>
</div>

<!-- About Content Section -->
<div class="container my-5">
    <div class="row">
        <div class="col-lg-8">
            <h2 class="mb-4">Who We Are</h2>
            <p class="lead mb-3">FirstMvcApp is a professional ASP.NET Core MVC application demonstrating best practices in modern web development.</p>
            <p>We believe in creating clean, maintainable, and scalable applications that solve real-world problems. Our team is committed to delivering high-quality solutions using the latest technologies.</p>
            
            <h3 class="mt-5 mb-3">Our Mission</h3>
            <p>To provide a solid foundation and best practices for building enterprise-level ASP.NET Core applications with emphasis on clean code, maintainability, and performance.</p>

            <h3 class="mt-5 mb-3">What Sets Us Apart</h3>
            <ul class="list-unstyled">
                <li class="mb-3"><strong>✓ Clean Architecture</strong> - Following SOLID principles and design patterns</li>
                <li class="mb-3"><strong>✓ Modern Technologies</strong> - Latest ASP.NET Core framework and tools</li>
                <li class="mb-3"><strong>✓ Best Practices</strong> - Industry-standard development practices</li>
                <li class="mb-3"><strong>✓ Scalability</strong> - Built to grow with your needs</li>
            </ul>
        </div>

        <div class="col-lg-4">
            <!-- Stats Section -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">By The Numbers</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-muted">Frameworks & Tools</h6>
                        <p class="h4 mb-0">ASP.NET Core 10</p>
                    </div>
                    <hr>
                    <div class="mb-3">
                        <h6 class="text-muted">UI Framework</h6>
                        <p class="h4 mb-0">Bootstrap 5</p>
                    </div>
                    <hr>
                    <div class="mb-3">
                        <h6 class="text-muted">Pattern</h6>
                        <p class="h4 mb-0">MVC</p>
                    </div>
                </div>
            </div>

            <!-- Contact Info Card -->
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="card-title mb-0">Get In Touch</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">Have questions? We'd love to hear from you.</p>
                    <a href="mailto:info@firstmvcapp.com" class="btn btn-primary w-100 mb-2">Send Email</a>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary w-100">Back to Home</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Why Choose Us Section -->
<div class="bg-light py-5 rounded mt-5">
    <div class="container">
        <h2 class="text-center mb-4">Why Choose FirstMvcApp?</h2>
        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <div class="display-6 text-primary">📱</div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5>Fully Responsive</h5>
                        <p class="text-muted">Works perfectly on all devices and screen sizes</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <div class="display-6 text-primary">⚡</div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5>High Performance</h5>
                        <p class="text-muted">Optimized for speed and efficiency</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <div class="display-6 text-primary">🔒</div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5>Secure</h5>
                        <p class="text-muted">Built-in security features and best practices</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="d-flex">
                    <div class="flex-shrink-0">
                        <div class="display-6 text-primary">🛠️</div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5>Easy to Maintain</h5>
                        <p class="text-muted">Clean code structure for easy updates and maintenance</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
